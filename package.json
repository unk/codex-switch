{
  "name": "@naram/codex-switch",
  "version": "0.1.3",
  "description": "Interactive CLI to set up isolated Codex profiles (multiple accounts / custom model providers) with one command.",
  "keywords": [
    "codex",
    "openai",
    "cli",
    "profile",
    "config"
  ],
  "license": "MIT",
  "author": "naram",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "codex-switch": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "tsc --noEmit && prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
